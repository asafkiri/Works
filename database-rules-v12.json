{
  "rules": {
    "config": {
      ".read": "auth != null",
      "managerUid": {
        ".write": "!data.exists() || data.val() === auth.uid"
      },
      "consolePin": {
        ".write": "root.child('config/managerUid').val() === auth.uid"
      },
      "taxConfig": {
        ".write": "root.child('config/managerUid').val() === auth.uid"
      },
      "takingsSeenAt": {
        ".write": "root.child('config/managerUid').val() === auth.uid"
      }
    },
    "employees": {
      ".read": "auth != null",
      "$empId": {
        ".write": "root.child('config/managerUid').val() === auth.uid",
        "authUid": {
          ".write": "root.child('config/managerUid').val() === auth.uid || ((!data.exists() || data.val() === auth.uid) && newData.val() === auth.uid)"
        },
        "linked": {
          ".write": "root.child('config/managerUid').val() === auth.uid || newData.parent().child('authUid').val() === auth.uid"
        },
        "tempPassword": {
          ".write": "root.child('config/managerUid').val() === auth.uid || (newData.parent().child('authUid').val() === auth.uid && !newData.exists())"
        },
        "notesSeenAt": {
          ".write": "root.child('config/managerUid').val() === auth.uid || data.parent().child('authUid').val() === auth.uid"
        }
      }
    },
    "takings": {
      ".read": "root.child('config/managerUid').val() === auth.uid",
      "$empId": {
        ".read": "root.child('config/managerUid').val() === auth.uid || root.child('employees/'+$empId+'/authUid').val() === auth.uid",
        "$takingId": {
          ".write": "root.child('config/managerUid').val() === auth.uid || (root.child('employees/'+$empId+'/authUid').val() === auth.uid && !data.exists())"
        }
      }
    },
    "shifts": {
      ".read": "auth != null",
      ".write": "root.child('config/managerUid').val() === auth.uid"
    },
    "recurringShifts": {
      ".read": "auth != null",
      ".write": "root.child('config/managerUid').val() === auth.uid"
    },
    "oneTimeShifts": {
      ".read": "auth != null",
      ".write": "root.child('config/managerUid').val() === auth.uid"
    }
  }
}
